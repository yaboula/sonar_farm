{
    "compilerOptions": {
        "composite": true,
        "target": "ES2022",
        "lib": ["ES2023"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "isolatedModules": true,
        "moduleDetection": "force",
        "types": ["node"],
        "emitDeclarationOnly": true,
        "outDir": "./node_modules/.cache/tsc-node",
        "rootDir": ".",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "skipLibCheck": true
    },
    "include": ["vite.config.ts"]
}
