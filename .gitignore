# ============================================================
# Farm Sonar — .gitignore
# ============================================================

# ---- Node / npm / pnpm / yarn ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/
.npm/

# ---- Vite / build outputs ----
dist/
build/
.vite/
*.local

# ---- TypeScript ----
*.tsbuildinfo

# ---- Environment files (NEVER commit secrets) ----
.env
.env.local
.env.*.local
.env.development
.env.production

# ---- IDE / editor ----
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Lua / FiveM ----
*.lua~
.lua_history

# ---- FiveM server runtime artifacts ----
cache/
server-data/
artifacts/
*.log
crash-*.log
fxserver.log

# ---- Database dumps / local DB ----
*.sql.bak
*.dump
*.sqlite
*.sqlite3
*.db

# ---- Test coverage ----
coverage/
.nyc_output/
*.lcov

# ---- Tebex / Asset Escrow build artifacts ----
escrowed/
*.escrowed.lua
release/
tebex_build/

# ---- OS junk ----
$RECYCLE.BIN/
ehthumbs.db
desktop.ini

# ---- Cascade / Windsurf local state (rules + workflows ARE tracked) ----
.windsurf/local/
.windsurf/cache/

# ---- Backup files ----
*.bak
*.orig
*.rej
*.tmp

# ---- Claude / Cursor / AI session caches ----
.claude/
.cursor/
.aider*

# ---- Founder personal scratchpad (never commit) ----
SCRATCH.md
NOTES_PRIVATE.md
TODO_PERSONAL.md
